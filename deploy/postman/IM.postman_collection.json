		{
			"name": "02-Group",
			"description": "群组业务：创建群、申请加群、处理申请、群列表、群成员",
			"item": [
				{
					"name": "01-用户A创建群",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json && json.id) {",
									"    pm.collectionVariables.set('group_id', json.id);",
									"}",
									"pm.test('Status 200', () => pm.response.to.have.status(200));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token_a}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"测试群聊\",\n    \"icon\": \"\"\n}"
						},
						"url": {
							"raw": "{{social_api}}/v1/social/group",
							"host": ["{{social_api}}"],
							"path": ["v1", "social", "group"]
						}
					}
				},
				{
					"name": "02-用户B申请加群",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token_b}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"group_id\": \"{{group_id}}\",\n    \"req_msg\": \"我想加入\",\n    \"req_time\": 1780000000,\n    \"join_source\": 1\n}"
						},
						"url": {
							"raw": "{{social_api}}/v1/social/group/putIn",
							"host": ["{{social_api}}"],
							"path": ["v1", "social", "group", "putIn"]
						}
					}
				},
				{
					"name": "03-用户A查看加群申请列表",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token_a}}" }
						],
						"url": {
							"raw": "{{social_api}}/v1/social/group/putIns?group_id={{group_id}}",
							"host": ["{{social_api}}"],
							"path": ["v1", "social", "group", "putIns"],
							"query": [
								{ "key": "group_id", "value": "{{group_id}}" }
							]
						}
					}
				},
				{
					"name": "04-用户A处理加群申请（通过）",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{token_a}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"group_id\": \"{{group_id}}\",\n    \"group_req_id\": 1,\n    \"handle_result\": 1\n}"
						},
						"url": {
							"raw": "{{social_api}}/v1/social/group/putIn",
							"host": ["{{social_api}}"],
							"path": ["v1", "social", "group", "putIn"]
						}
					}
				},
				{
					"name": "05-查看群成员列表",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token_a}}" }
						],
						"url": {
							"raw": "{{social_api}}/v1/social/group/users?group_id={{group_id}}",
							"host": ["{{social_api}}"],
							"path": ["v1", "social", "group", "users"],
							"query": [
								{ "key": "group_id", "value": "{{group_id}}" }
							]
						}
					}
				},
				{
					"name": "06-查看用户的群列表",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token_a}}" }
						],
						"url": {
							"raw": "{{social_api}}/v1/social/groups",
							"host": ["{{social_api}}"],
							"path": ["v1", "social", "groups"]
						}
					}
				}
			]
		},
