						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"13800000001\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{user_api}}/v1/user/login",
							"host": ["{{user_api}}"],
							"path": ["v1", "user", "login"]
						}
					}
				},
				{
					"name": "04-登录用户B",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json && json.token) {",
									"    pm.collectionVariables.set('token_b', json.token);",
									"}",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));"
								],
								"type": "text/javascript"
							}
