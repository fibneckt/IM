{
	"info": {
		"_postman_id": "im-test-collection",
		"name": "IM 服务测试",
		"description": "IM 项目全部 API 测试用例，覆盖 user 和 social 两个服务",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "user_api",
			"value": "http://127.0.0.1:8080",
			"type": "string"
		},
		{
			"key": "social_api",
			"value": "http://127.0.0.1:8081",
			"type": "string"
		},
		{
			"key": "token_a",
			"value": "",
			"type": "string"
		},
		{
			"key": "token_b",
			"value": "",
			"type": "string"
		},
		{
			"key": "group_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_a_id",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_b_id",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "01-User",
			"description": "用户服务：注册、登录、查询用户信息",
			"item": [
				{
					"name": "01-注册用户A",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json && json.token) {",
									"    pm.collectionVariables.set('token_a', json.token);",
									"}",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"\",\n    \"mobile\": \"13800000001\",\n    \"nickname\": \"张三\",\n    \"password\": \"123456\",\n    \"avatar\": \"\",\n    \"sex\": 1\n}"
						},
						"url": {
							"raw": "{{user_api}}/v1/user/register",
							"host": ["{{user_api}}"],
							"path": ["v1", "user", "register"]
						}
					}
				},
				{
					"name": "02-注册用户B",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if (json && json.token) {",
									"    pm.collectionVariables.set('token_b', json.token);",
									"}",
									"pm.test('Status 200', () => pm.response.to.have.status(200));",
									"pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"id\": \"\",\n    \"mobile\": \"13800000002\",\n    \"nickname\": \"李四\",\n    \"password\": \"123456\",\n    \"avatar\": \"\",\n    \"sex\": 0\n}"
						},
						"url": {
							"raw": "{{user_api}}/v1/user/register",
							"host": ["{{user_api}}"],
							"path": ["v1", "user", "register"]
						}
					}
				},
				{
					"name": "03-登录用户A",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
