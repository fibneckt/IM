						"body": {
							"mode": "raw",
							"raw": "{\n    \"phone\": \"13800000002\",\n    \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{user_api}}/v1/user/login",
							"host": ["{{user_api}}"],
							"path": ["v1", "user", "login"]
						}
					}
				},
				{
					"name": "05-获取用户A信息",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token_a}}" }
						],
						"url": {
							"raw": "{{user_api}}/v1/user/user",
							"host": ["{{user_api}}"],
							"path": ["v1", "user", "user"]
						}
					}
				},
				{
					"name": "06-获取用户B信息",
					"request": {
						"method": "GET",
						"header": [
